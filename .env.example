# ─────────────────────────────────────────────────────────────────────────────
# FinBank — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le .env sur git
# ─────────────────────────────────────────────────────────────────────────────

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Clé privée du deployer (wallet de déploiement, pas le multisig DAO)
DEPLOYER_PK=

# API key Basescan (pour la vérification des contrats)
BASESCAN_API_KEY=
