# Réseau (sepolia | mainnet)
NETWORK=sepolia

# RPC Alchemy
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Base de données PostgreSQL
DATABASE_URL=postgresql://finbank:password@localhost:5432/finbank

# Port de l'API
API_PORT=3001

# Adresses des contrats (remplir après déploiement Sepolia)
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
FBK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VE_FBK_ADDRESS=0x0000000000000000000000000000000000000000
FBK_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
EAS_CHECKER_ADDRESS=0x0000000000000000000000000000000000000000

# Bloc de départ de l'indexeur (bloc du déploiement)
START_BLOCK=0

# Intervalle de polling en ms (5 secondes)
POLL_INTERVAL_MS=5000
