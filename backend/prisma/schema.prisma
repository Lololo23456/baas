generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Dépôts dans le Vault ──────────────────────────────────────────────────────

model Deposit {
  id        String   @id @default(cuid())
  txHash    String   @unique
  blockNumber BigInt
  timestamp DateTime
  caller    String   // msg.sender
  owner     String   // receiver des shares
  assets    String   // EURC déposés (uint256 as string)
  shares    String   // fbEURC reçus (uint256 as string)

  @@index([owner])
  @@index([blockNumber])
}

// ── Retraits du Vault ─────────────────────────────────────────────────────────

model Withdrawal {
  id        String   @id @default(cuid())
  txHash    String   @unique
  blockNumber BigInt
  timestamp DateTime
  caller    String
  receiver  String
  owner     String
  assets    String
  shares    String

  @@index([owner])
  @@index([blockNumber])
}

// ── Claims de $FBK ────────────────────────────────────────────────────────────

model Claim {
  id        String   @id @default(cuid())
  txHash    String   @unique
  blockNumber BigInt
  timestamp DateTime
  user      String
  amount    String   // FBK claimés (uint256 as string)

  @@index([user])
  @@index([blockNumber])
}

// ── Locks veFBK ───────────────────────────────────────────────────────────────

model Lock {
  id         String   @id @default(cuid())
  txHash     String   @unique
  blockNumber BigInt
  timestamp  DateTime
  user       String
  amount     String
  unlockTime DateTime
  eventType  LockEventType

  @@index([user])
}

enum LockEventType {
  CREATED
  INCREASED
  EXTENDED
  WITHDRAWN
}

// ── Propositions de gouvernance ───────────────────────────────────────────────

model Proposal {
  id          String   @id @default(cuid())
  proposalId  String   @unique  // uint256 as string
  txHash      String
  blockNumber BigInt
  timestamp   DateTime
  proposer    String
  description String
  voteStart   String   // block number
  voteEnd     String   // block number
  targets     String[] // JSON array of addresses
  calldatas   String[] // JSON array of calldata
  forVotes    String   @default("0")
  againstVotes String  @default("0")
  abstainVotes String  @default("0")
  executed    Boolean  @default(false)
  canceled    Boolean  @default(false)

  votes       Vote[]

  @@index([proposer])
}

// ── Votes ─────────────────────────────────────────────────────────────────────

model Vote {
  id          String   @id @default(cuid())
  txHash      String   @unique
  blockNumber BigInt
  timestamp   DateTime
  proposalId  String
  voter       String
  voteType    VoteType
  weight      String   // veFBK au snapshot

  proposal    Proposal @relation(fields: [proposalId], references: [proposalId])

  @@index([voter])
  @@index([proposalId])
}

enum VoteType {
  AGAINST
  FOR
  ABSTAIN
}

// ── État de l'indexeur ────────────────────────────────────────────────────────

model IndexerState {
  id          String @id @default("singleton")
  lastBlock   BigInt @default(0)
  updatedAt   DateTime @updatedAt
}
